{
  "expo": {
    "name": "CompraPro",
    "slug": "comprapro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0052CC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.comprapro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0052CC"
      },
      "package": "com.comprapro.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "comprapro",
    "extra": {
      "API_URL": "http://192.168.1.100:8080"
    }
  }
}
